# Django General Settings
# -----------------------
# Set to False in production
DEBUG=False

# Generate a strong, unique secret key for production:
# python3 -c 'import secrets; print(secrets.token_hex(50))'
SECRET_KEY=your-production-django-secret-key-here

# Comma-separated list of hosts/domains this site is allowed to serve:
ALLOWED_HOSTS=helpdesk.example.com,12.34.56.78

# The absolute base URL of your site (used for generating links in emails):
SITE_URL=https://helpdesk.example.com


# Database Settings (PostgreSQL in production)
# --------------------------------------------
# Syntax: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://helpdesk_user:your_secure_password_here@localhost:5432/helpdesk_db


# Email Configuration (SMTP settings)
# -----------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_smtp_app_password_here
DEFAULT_FROM_EMAIL=IT Helpdesk <noreply@example.com>


# Production Security and Logs
# ----------------------------
# Set to 'False' if Nginx handles SSL redirection, or keep 'True' for Django-level redirect
SECURE_SSL_REDIRECT=True

# Directory where Django and Gunicorn write log files
LOG_DIR=/var/log/helpdesk
